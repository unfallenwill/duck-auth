# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
/lib/generated/prisma
prisma/dev.db
prisma/dev.db-journal
# SQLite default location at project root (matches DATABASE_URL=file:./dev.db)
dev.db
dev.db-journal

# oauth keys (RSA private key — DO NOT COMMIT)
/.oauth-keys.json

# test coverage
/coverage
*.lcov

# playwright
test-results/
playwright-report/

# prisma cli skill cache (auto-generated by Prisma 7)
/.agents/
/.claude/
/.windsurf/
skills-lock.json

# AI agent rules (auto-generated by Next.js / Prisma)
AGENTS.md
CLAUDE.md

# debug artifacts
cookies*.txt
staged-files.txt
