{
  "name": "duck-auth",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:cleanup": "tsx scripts/cleanup-tokens.ts",
    "db:keys:init": "tsx scripts/init-keys.ts",
    "e2e": "tsx e2e/flow.ts",
    "e2e:browser": "tsx e2e/browser-flow.ts",
    "e2e:consent": "tsx e2e/consent-flow.ts",
    "e2e:security": "tsx e2e/security-extra.ts",
    "audit:tokens": "tsx e2e/audit-tokens.ts",
    "e2e:revocation": "tsx e2e/session-revocation.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "npm run e2e && npm run e2e:consent && npm run e2e:browser && npm run audit:tokens && npm run e2e:security && npm run e2e:revocation",
    "e2e:playwright": "playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "test:browser": "npm run test:unit && npm run test:e2e && npm run e2e:playwright",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@libsql/client": "^0.17.4",
    "@prisma/adapter-libsql": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@tailwindcss/postcss": "^4.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "postcss": "^8.5.21",
    "prisma": "^7.9.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^17.4.2",
    "eslint": "^10",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix"
  }
}